{
  "compatibility_date": "2026-01-27",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat",
    "disable_nodejs_process_v2",
  ],
  "name": "astro-medusa-starter",
  "main": "@astrojs/cloudflare/entrypoints/server",
  "assets": {
    "directory": "./dist",
    "binding": "ASSETS",
  },
  "observability": {
    "enabled": true,
  },
}
