---
import Layout from '@layouts/Layout.astro'
import { retrieveProduct } from '@lib/data/products'
import { getRegion } from '@lib/data/regions'
import { getProductPrice } from '@lib/utils/get-product-price'
import ImageCarouselWrapper from '@modules/products/components/product-details/image-carousel/ImageCarouselWrapper.astro'
import { ProductActions } from '@modules/products/components/product-details/ProductActions'
import ProductAttributes from '@modules/products/components/product-details/ProductAttributes.astro'

export const prerender = false

const { countryCode, productId } = Astro.params

let product: Awaited<ReturnType<typeof retrieveProduct>> | undefined
let errorMessage: string | undefined
let statusCode = 200

const region = countryCode ? await getRegion(countryCode) : null

if (!countryCode || !productId || !region) {
  statusCode = 404
  errorMessage = 'Product not found'
} else {
  try {
    product = await retrieveProduct(productId, region.id)

    if (!product) {
      statusCode = 404
      errorMessage = 'Product not found'
    }
  } catch (e) {
    const status = e instanceof Error && 'status' in e ? e.status : undefined

    statusCode = status === 404 ? 404 : 500
    errorMessage =
      e instanceof Error ? e.message : 'Unable to load this product right now'
    console.error(e)
  }
}

Astro.response.status = statusCode

const {
  title,
  description,
  images,
  options,
  variants,
  material,
  origin_country,
  type,
  weight,
  length,
  width,
  height
} = product ?? {}

const { cheapestPrice } = getProductPrice({
  productVariants: variants ?? []
})

const pageTitle =
  title ?? (statusCode === 404 ? 'Product not found' : 'Product unavailable')
---

<Layout
  title={pageTitle}
  description={description ?? `Shop ${pageTitle} at the best price.`}
  image={images?.[0]?.url}
  type="product"
  noindex={statusCode !== 200}
>
  {errorMessage && <p class="px-8 py-6 text-red-700 md:px-12 lg:px-16">{errorMessage}</p>}
  {
    product && region && (
      <div class="grid grid-cols-1 gap-20 px-8 py-6 md:px-12 lg:grid-cols-2 lg:px-16">
        <ImageCarouselWrapper
          images={images ?? []}
          alt={title ?? 'Product image'}
        />

        <div class="flex flex-col gap-20">
          <div class="flex flex-col gap-4">
            <h1 class="text-4xl font-bold">{title}</h1>
            <p class="text-gray-500">{description}</p>
            <p class="text-4xl font-bold">{cheapestPrice?.calculated_price}</p>
          </div>

          <ProductActions
            options={options ?? []}
            variants={variants ?? []}
            productId={productId}
            regionId={region.id}
            client:visible
          />

          <ProductAttributes
            material={material}
            origin_country={origin_country}
            type={type}
            weight={weight}
            length={length}
            width={width}
            height={height}
          />
        </div>
      </div>
    )
  }
</Layout>
